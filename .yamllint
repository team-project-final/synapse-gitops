---
extends: default

rules:
  line-length:
    max: 160
    level: warning
  indentation:
    spaces: 2
    indent-sequences: true
  document-start: disable
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  empty-lines:
    max: 2
  trailing-spaces: enable

ignore: |
  .terraform/
  node_modules/
  .git/
  infra/k8s-addons/
