# ─── Synapse Local Development Environment Variables ────────────────────────
# Copy to .env and fill in actual values where needed
# Usage: cp .env.example .env && docker compose up -d

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_local

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_local

# ─── Image Registry ─────────────────────────────────────────────────────────
ECR_REGISTRY=ghcr.io/team-project-final
IMAGE_TAG=latest

# ─── Platform Service ───────────────────────────────────────────────────────
JWT_SECRET=local-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256-algorithm
OAUTH_GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
OAUTH_GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
STRIPE_API_KEY=sk_test_<YOUR_STRIPE_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_STRIPE_WEBHOOK_SECRET>
FCM_PROJECT_ID=synapse-local

# ─── Knowledge Service ──────────────────────────────────────────────────────
AWS_S3_ENDPOINT_URL=http://localhost:4566
AWS_S3_BUCKET_NAME=synapse-attachments-local

# ─── Learning AI Service ────────────────────────────────────────────────────
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
